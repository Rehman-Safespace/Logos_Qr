rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Security Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    // Validation Blueprint Helper for Memory Documents
    function isValidMemory(data) {
      return data.keys().hasAll(['key', 'root', 'insight', 'timestamp', 'ownerId'])
        && data.keys().size() == 5
        && data.key is string && data.key.size() <= 128
        && data.root is string && data.root.size() <= 32
        && data.insight is string && data.insight.size() <= 5000
        && data.timestamp is string && data.timestamp.size() <= 64
        && data.ownerId is string && data.ownerId.size() <= 128
        && isOwner(data.ownerId);
    }

    // Rules matching the /memories/{memoryId} path
    match /memories/{memoryId} {
      allow get: if isSignedIn() && isOwner(resource.data.ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(memoryId)
        && isValidMemory(request.resource.data);
        
      allow update: if isSignedIn()
        && isValidId(memoryId)
        && isValidMemory(request.resource.data)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.key == resource.data.key
        && request.resource.data.root == resource.data.root;
        
      allow delete: if isSignedIn() 
        && isOwner(resource.data.ownerId);
    }
  }
}
